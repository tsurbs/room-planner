# Vercel — link Storage → KV or use Upstash REST (same env names)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Must match PartyKit deployment (PartyKit → Settings → Environment variables)
# API routes reject unauthenticated PUT /api/plans/[id] unless this is unset (not recommended for prod)
PARTYKIT_SERVERS_SECRET=

# PartyKit worker → HTTP snapshot load + PUT flush (your Vercel deployment origin, no trailing slash)
# Example: https://roomplanner-rose.vercel.app  or https://roomplanner.theourban.com
PLANDS_API_ORIGIN=
